# --- CONFIGURAÇÕES DA BASE DE DADOS ---
# Altera para as tuas credenciais de acesso ao PostgreSQL
DB_USER = "user"
DB_PASS = "password" 
DB_HOST = "host"
DB_PORT = "port" 
DB_NAME = "db_name"

SCHEMA_NAME = "schema_name" 

# Opções de destino dos dados
SAVE_LOCAL_FILE = False  # True: Cria o GeoPackage localmente
UPLOAD_TO_POSTGRES = True   # True: Envia os dados para a Base de Dados 

DATABASE_URL = f"postgresql://{DB_USER}:{DB_PASS}@{DB_HOST}:{DB_PORT}/{DB_NAME}"