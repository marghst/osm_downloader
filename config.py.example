LAYER_COLUMNS = {
    "roads": ['id', 'element', 'name', 'highway', 'geometry'],
    "pois": ['id', 'element', 'name', 'brand', 'operator', 'amenity', 'craft', 'historic', 'office', 'shop', 'tourism', 'leisure', 'geometry'],
    "places": ['id', 'element', 'place', 'name', 'geometry', 'alt_name']
}

